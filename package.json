{
  "name": "fitex",
  "version": "0.1.0",
  "private": true,
  "description": "Fitex - Make your LaTeX CV fit the job description",
  "scripts": {
    "dev:web": "pnpm --filter @fitex/web dev",
    "dev:api": "pnpm --filter @fitex/api start:dev",
    "dev:extension": "pnpm --filter @fitex/extension dev",
    "build:web": "pnpm --filter @fitex/web build",
    "build:api": "pnpm --filter @fitex/api build",
    "build:extension": "pnpm --filter @fitex/extension build",
    "lint": "pnpm -r lint",
    "format": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:fix": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "pnpm -r test",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.13.2",
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
